ENV=local

MONGO_URI_LOCAL=mongodb://127.0.0.1:27017/schedular
MONGO_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/schedular

REDIRECT_URI_LOCAL=http://localhost:5000/api/linkedin/callback
REDIRECT_URI_PROD=https://your-api-domain.com/api/linkedin/callback

FRONTEND_URL_LOCAL=http://localhost:5173
FRONTEND_URL_PROD=https://your-frontend-domain.com

PORT=5000
JWT_SECRET=replace-with-a-strong-random-secret

LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
